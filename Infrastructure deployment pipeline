  region = "ap-south-1"
}
```

---

## Create EC2 Instance

```hcl
resource "aws_instance" "web" {

  ami           = "ami-0f58b397bc5c1f2e8"
  instance_type = "t3.micro"

  tags = {
    Name = "web-server"
  }
}
```

Deploy:

```bash
terraform init
terraform plan
terraform apply
```

